    "@mysten/sui": "^2.20.3",
    "@mysten/walrus": "^1.2.5",
    "@tailwindcss/vite": "^4.3.2",
    "ai": "^7.0.22",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
