  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c teal,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
