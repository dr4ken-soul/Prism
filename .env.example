# Server
PORT=8787

# LLM provider: auto | anthropic | groq
# auto = Anthropic if key set, otherwise Groq
LLM_PROVIDER=auto
# Try the other provider if the primary fails (true | false)
LLM_FALLBACK=true

# Anthropic (never expose to the client bundle)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Groq (never expose to the client bundle)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# MemWal Mainnet (never expose to the client bundle)
MEMWAL_DELEGATE_KEY=
MEMWAL_ACCOUNT_ID=
MEMWAL_RELAYER_URL=https://relayer.memory.walrus.xyz
MEMWAL_NETWORK=mainnet
